{
  "manifest_version": 3,
  "name": "Link Visit Counter",
  "version": "1.0",
  "description": "Offline productivity tracker with domain-level time and visit insights.",
  "permissions": ["storage", "tabs", "idle", "notifications", "downloads"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
